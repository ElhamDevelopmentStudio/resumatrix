RESUMATRIX_AUTH_USERNAME=admin
RESUMATRIX_AUTH_PASSWORD=change-me
RESUMATRIX_SESSION_SECRET=replace-with-a-long-random-string
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

AI_PROVIDER=minimax
AI_REQUEST_TIMEOUT_MS=45000

MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/v1/text/chatcompletion_v2
MINIMAX_MODEL=MiniMax-M2.7

GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=openai/gpt-oss-20b
GROQ_RESPONSE_FORMAT=json_schema
GROQ_JSON_SCHEMA_STRICT=true

NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_RESPONSE_FORMAT=json_object
NVIDIA_JSON_SCHEMA_STRICT=false
